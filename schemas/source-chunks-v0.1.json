{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kiu.source-chunks/v0.1",
  "title": "KiU Source Chunks v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_id",
    "source_id",
    "source_file",
    "language",
    "chunks"
  ],
  "properties": {
    "schema_version": {
      "const": "kiu.source-chunks/v0.1"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "source_file": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "chunks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "chunk_id",
          "source_id",
          "source_file",
          "chapter",
          "section",
          "line_start",
          "line_end",
          "chunk_text",
          "token_estimate",
          "language"
        ],
        "properties": {
          "chunk_id": { "type": "string", "minLength": 1 },
          "source_id": { "type": "string", "minLength": 1 },
          "source_file": { "type": "string", "minLength": 1 },
          "chapter": { "type": "string", "minLength": 1 },
          "section": { "type": "string", "minLength": 1 },
          "line_start": { "type": "integer", "minimum": 1 },
          "line_end": { "type": "integer", "minimum": 1 },
          "chunk_text": { "type": "string", "minLength": 1 },
          "token_estimate": { "type": "integer", "minimum": 0 },
          "language": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
