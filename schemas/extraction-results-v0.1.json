{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kiu.extraction-results/v0.1",
  "title": "KiU Extraction Results v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_id",
    "source_id",
    "source_file",
    "input_chunk_count",
    "chunk_ids",
    "nodes",
    "edges",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "kiu.extraction-results/v0.1"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "source_file": {
      "type": "string",
      "minLength": 1
    },
    "input_chunk_count": {
      "type": "integer",
      "minimum": 0
    },
    "chunk_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "label",
          "source_file",
          "extraction_kind"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "source_file": { "type": "string", "minLength": 1 },
          "extraction_kind": {
            "enum": ["EXTRACTED", "INFERRED", "AMBIGUOUS"]
          }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "from",
          "to",
          "extraction_kind",
          "confidence"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "extraction_kind": {
            "enum": ["EXTRACTED", "INFERRED", "AMBIGUOUS"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          }
        },
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
